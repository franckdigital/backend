SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ──────────────────────────────────────────────────
# Base de données Django (sav_pharmacie)
# Le VPS Django se connecte au MySQL du serveur WinDev
# DB_HOST = IP publique ou VPN du serveur MySQL WinDev
# ──────────────────────────────────────────────────
DB_ENGINE=mysql
DB_NAME=sav_pharmacie
DB_USER=sav_app
DB_PASSWORD=your-strong-password
DB_HOST=IP_SERVEUR_WINDEV
DB_PORT=3306

# ──────────────────────────────────────────────────
# Base WinDev (FacturationClient) - LECTURE SEULE
# Même serveur MySQL que l'app WinDev
# Django lit cette base pour synchroniser les données
# ──────────────────────────────────────────────────
WINDEV_DB_NAME=FacturationClient
WINDEV_DB_USER=sav_sync
WINDEV_DB_PASSWORD=your-sync-password
WINDEV_DB_HOST=IP_SERVEUR_WINDEV
WINDEV_DB_PORT=3306

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Google Maps API Key (optional)
GOOGLE_MAPS_API_KEY=

# ──────────────────────────────────────────────────
# Celery + Redis (synchronisation périodique)
# ──────────────────────────────────────────────────
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
SYNC_INTERVAL_SECONDS=120
